			"scheme": "https",
			"authority": "codism-demo.pages.dev",
			"path": "static/extensions/vscode-web-playground"
		},
		{
			"scheme": "https",
			"authority": "codism-demo.pages.dev",
			"path": "static/extensions/wasm-risc-v"
		}
	]
}